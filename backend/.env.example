PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# PostgreSQL connection string (local or cloud)
DATABASE_URL=postgresql://postgres:password@localhost:5432/memento

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback
GOOGLE_GMAIL_CALLBACK_URL=http://localhost:3001/api/v1/gmail/callback

# Session — use a long random string (min 32 chars)
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d
SESSION_COOKIE_NAME=memento_session

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback
GOOGLE_GMAIL_CALLBACK_URL=http://localhost:3001/api/v1/gmail/callback

# Session — use a long random string (min 32 chars)
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d
SESSION_COOKIE_NAME=memento_session

# Encrypt Gmail refresh tokens at rest (min 32 chars)
ENCRYPTION_KEY=change-me-to-a-long-random-encryption-key-32+

# Gemini (Google AI Studio) — required for Gmail sync/extraction
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Gmail sync tuning
GMAIL_SYNC_WINDOW_DAYS=30
GMAIL_MAX_MESSAGES=100
GMAIL_LLM_BATCH_SIZE=15
GMAIL_MIN_CONFIDENCE=0.4

# Optional legacy AI key
OPENAI_API_KEY=

