PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# PostgreSQL connection string (local or cloud)
DATABASE_URL=postgresql://postgres:password@localhost:5432/memento

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# Session — use a long random string (min 32 chars)
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d
SESSION_COOKIE_NAME=memento_session

# AI Provider (add your key when ready)
OPENAI_API_KEY=

